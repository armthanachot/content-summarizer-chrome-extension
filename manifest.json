{
  "manifest_version": 3,
  "name": "Content Summarizer",
  "version": "1.3.0",
  "description": "Summarize any content using OpenAI GPT-4o mini with beautiful markdown rendering",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Content Summarizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["file.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon48.png",
        "icons/translate.png",
        "icons/assistant.png",
        "icons/open_icon.svg",
        "icons/icons8-clip-24.png",
        "icons/icons8-json-50.png",
        "icons/icons8-markdown-36.png",
        "icons/icons8-menu-vertical-100.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
